# Copy to .env and fill in values (do not commit .env)

# Required for AI audit and secure coding labs
ANTHROPIC_API_KEY=

# Change in production
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_EMAIL=admin@cyberaudit.local

# dev = H2 in-memory (default), prod = PostgreSQL
SPRING_PROFILES_ACTIVE=dev

# PostgreSQL (only when SPRING_PROFILES_ACTIVE=prod)
# DATABASE_URL=jdbc:postgresql://localhost:5432/cyberaudit
# DATABASE_USERNAME=cyberaudit
# DATABASE_PASSWORD=your-db-password

# CORS (comma-separated origins)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
